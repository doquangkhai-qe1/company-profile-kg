# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j
# Optional TLS: path (relative to repo root, or absolute) to a custom CA/server
# cert (PEM) to trust. Set this for a remote bolt:// server with a self-signed
# cert. Leave empty for plain local connections. Do NOT use with bolt+s/bolt+ssc.
# NEO4J_TLS_CERT=public.crt

# ── Graphiti tier-2 LLM provider (switchable) ────────────────────────────────
# Graphiti's internal entity/edge extraction uses this LLM. Pick a provider:
#   openai      → any OpenAI-compatible endpoint. LOCAL Ollama (free) OR api.openai.com.
#   anthropic   → Anthropic API. Needs ANTHROPIC_API_KEY + `pip install graphiti-core[anthropic]`. PAID.
#   claude_code → the `claude` CLI (Claude Code). Covered by the Max plan, no API key.
# Models map by call size: LLM_SMALL_MODEL for light calls (dedup), LLM_MODEL for the rest.
LLM_PROVIDER=openai
LLM_MODEL=qwen2.5:7b
LLM_SMALL_MODEL=qwen2.5:7b
# openai provider only (ignored by anthropic/claude_code):
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
# Example — Claude Code (Max plan), Haiku+Sonnet mix:
#   LLM_PROVIDER=claude_code
#   LLM_MODEL=claude-sonnet-4-6
#   LLM_SMALL_MODEL=claude-haiku-4-5
# Example — Anthropic API (paid):
#   LLM_PROVIDER=anthropic
#   ANTHROPIC_API_KEY=sk-ant-...
#   LLM_MODEL=claude-sonnet-4-6
#   LLM_SMALL_MODEL=claude-haiku-4-5
# Example — OpenAI API (paid):
#   LLM_PROVIDER=openai
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_API_KEY=sk-...
#   LLM_MODEL=gpt-4o
#   LLM_SMALL_MODEL=gpt-4o-mini

# ── Embeddings: ALWAYS via an OpenAI-compatible endpoint (Ollama) ─────────────
# Anthropic / Claude Code have no embeddings endpoint, so this stays on Ollama.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_LLM_MODEL=qwen2.5:7b
EMBED_MODEL=bge-m3
EMBEDDING_DIM=1024
# Reserved output tokens (counts against context); clamp keeps small models honest.
LLM_MAX_TOKENS=2048
SEMAPHORE_LIMIT=4

# group_id namespaces all episodes for this system (isolated from other KGs).
KG_GROUP_ID=company-profile

# ── Extraction via Claude Code headless (covered by Max plan) ────────────────
# Must be logged in (`claude` once interactively) so cron/launchd can run headless.
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_S=600

# ── Crawler ──────────────────────────────────────────────────────────────────
CRAWL_RATE_S=3
CRAWL_USER_AGENT=company-profile-kg/0.1 (+research; contact: you@example.com)
CRAWL_TIMEOUT_S=30

# Optional: override the tickers config path
# TICKERS_FILE=config/tickers.yaml
