# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# ── Graphiti tier-2: LLM + embedder via local Ollama (OpenAI-compatible) ─────
# Graphiti's internal entity/edge extraction uses this LLM. Keep it LOCAL/free —
# the Claude Max subscription does NOT cover the Anthropic API graphiti would call.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_LLM_MODEL=qwen2.5:7b
EMBED_MODEL=bge-m3
EMBEDDING_DIM=1024
# Reserved output tokens (counts against context); clamp keeps small models honest.
LLM_MAX_TOKENS=2048
SEMAPHORE_LIMIT=4

# group_id namespaces all episodes for this system (isolated from other KGs).
KG_GROUP_ID=company-profile

# ── Extraction via Claude Code headless (covered by Max plan) ────────────────
# Must be logged in (`claude` once interactively) so cron/launchd can run headless.
CLAUDE_BIN=claude
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_S=600

# ── Crawler ──────────────────────────────────────────────────────────────────
CRAWL_RATE_S=3
CRAWL_USER_AGENT=company-profile-kg/0.1 (+research; contact: you@example.com)
CRAWL_TIMEOUT_S=30

# Optional: override the tickers config path
# TICKERS_FILE=config/tickers.yaml
